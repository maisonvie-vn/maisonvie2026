@import "tailwindcss";

@theme {
  --font-serif: var(--font-cormorant), Georgia, serif;
  --font-sans: var(--font-montserrat), sans-serif;
  
  --color-gold-50: #FAF8F2;
  --color-gold-100: #F4ECCF;
  --color-gold-200: #E6D69D;
  --color-gold-300: #D8BF6B;
  --color-gold-400: #CBA942;
  --color-gold-500: #C5A55A; /* Base Luxury Gold */
  --color-gold-600: #AB883F;
  --color-gold-700: #8E6E32;
  --color-gold-800: #715525;
  --color-gold-900: #543E19;
  --color-gold-950: #38270E;
  
  --color-dark-50: #516268;
  --color-dark-100: #26414b;
  --color-dark-200: #1e353d;
  --color-dark-300: #172a30;
  --color-dark-400: #0c1315; /* Darker Moss Green for panels/cards */
  --color-dark-500: #111d22; /* Lighter Moss Green for main background */
  --color-dark-600: #0e181c;
  --color-dark-700: #0b1317;
  --color-dark-900: #060b0c;
}

:root {
  --background: #111d22;
  --foreground: #F5F5F4;
  --gold: #C5A55A;
  --gold-glow: rgba(197, 165, 90, 0.15);
  --border-gold: rgba(197, 165, 90, 0.2);
}

html {
  scroll-behavior: smooth;
}

body {
  background-color: var(--background);
  color: var(--foreground);
  overflow-x: hidden;
}

/* Headings utilize the luxury Cormorant Garamond serif font */
h1, h2, h3, h4, h5, h6, .font-luxury {
  font-family: var(--font-serif);
  letter-spacing: 0.03em;
}

/* Base custom visual tokens */
.gold-text-gradient {
  background: linear-gradient(135deg, #FAF8F2 0%, #D8BF6B 50%, #C5A55A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.gold-border-glow {
  border: 1px solid var(--border-gold);
  box-shadow: 0 0 15px rgba(197, 165, 90, 0.05);
  transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.gold-border-glow:hover {
  border-color: rgba(197, 165, 90, 0.5);
  box-shadow: 0 0 25px rgba(197, 165, 90, 0.15);
}

.glassmorphism {
  background: rgba(17, 29, 34, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.03);
}

/* Micro-animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(15px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.transition-premium {
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Custom styling to make native date picker icon gold */
input[type="date"]::-webkit-calendar-picker-indicator {
  filter: invert(72%) sepia(21%) saturate(1005%) hue-rotate(5deg) brightness(96%) contrast(89%);
  cursor: pointer;
}

