@import "tailwindcss";

@theme {
  --font-serif: var(--font-cormorant), Georgia, serif;
  --font-sans: var(--font-montserrat), sans-serif;
  
  --color-gold-50: #FAF8F2;
  --color-gold-100: #F6F0DF;
  --color-gold-200: #EBDEBD;
  --color-gold-300: #DEC797;
  --color-gold-400: #CBAF73;
  --color-gold-500: #A8884E; /* Base Luxury Gold / Accent brass */
  --color-gold-600: #93743E;
  --color-gold-700: #7A5F31;
  --color-gold-800: #614B25;
  --color-gold-900: #49371B;
  --color-gold-950: #302410;
  
  --color-dark-50: #102B2A;
  --color-dark-100: #102B2A;
  --color-dark-200: #042726;
  --color-dark-300: #042726;
  --color-dark-400: #042726; /* Phụ: Darker Moss Green for panels/cards */
  --color-dark-500: #102B2A; /* Nền: Lighter Moss Green for main background */
  --color-dark-600: #042726;
  --color-dark-700: #042726;
  --color-dark-900: #042726;
}

:root {
  --background: #102B2A;
  --foreground: #FFFFFF;
  --gold: #A8884E;
  --gold-glow: rgba(168, 136, 78, 0.15);
  --border-gold: rgba(168, 136, 78, 0.2);
}

html {
  scroll-behavior: smooth;
}

body {
  background-color: var(--background);
  color: var(--foreground);
  overflow-x: hidden;
}

/* Headings utilize the luxury Cormorant Garamond serif font */
h1, h2, h3, h4, h5, h6, .font-luxury {
  font-family: var(--font-serif);
  letter-spacing: 0.03em;
}

/* Base custom visual tokens */
.gold-text-gradient {
  background: linear-gradient(135deg, #FFFFFF 0%, #DEC797 50%, #A8884E 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.gold-border-glow {
  border: 1px solid var(--border-gold);
  box-shadow: 0 0 15px rgba(168, 136, 78, 0.05);
  transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.gold-border-glow:hover {
  border-color: rgba(168, 136, 78, 0.5);
  box-shadow: 0 0 25px rgba(168, 136, 78, 0.15);
}

.glassmorphism {
  background: rgba(16, 43, 42, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.03);
}

/* Micro-animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(15px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.transition-premium {
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Custom styling to make native date picker icon gold */
input[type="date"]::-webkit-calendar-picker-indicator {
  filter: invert(72%) sepia(21%) saturate(1005%) hue-rotate(5deg) brightness(96%) contrast(89%);
  cursor: pointer;
}

